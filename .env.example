# Configuração de Segurança - Erivan Estacionamento

# Ambiente de execução (production, development, test)
NODE_ENV=production

# Porta do servidor
PORT=3000

# Origens permitidas para CORS (separadas por vírgula)
# IMPORTANTE: Em produção, use apenas domínios confiáveis
ALLOWED_ORIGINS=http://localhost:3000,https://erivan-estacionamento.vercel.app,https://www.erivan-estacionamento.com.br

# Email para notificações de segurança
ADMIN_EMAIL=seu-email@exemplo.com

# Chave secreta para sessões (gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SECRET_KEY=sua-chave-secreta-aleatoria-aqui

# Banco de dados (quando implementado)
# DATABASE_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/dbname

# API Keys (se necessário)
# SENDGRID_API_KEY=sua-chave-aqui
# RECAPTCHA_SECRET_KEY=sua-chave-aqui

# Configurações de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CONTACT_LIMIT_WINDOW_MS=3600000
CONTACT_LIMIT_MAX_REQUESTS=10
